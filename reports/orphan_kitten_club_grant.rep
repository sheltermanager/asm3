Orphan Kitten Club Grant
###
Figures
###
34801/Any rev01
###
Figures needed to complete the Orphan Kitten Club gran application
###
en
###
$VAR year NUMBER Enter the year, eg: 2025$

SELECT

'$@year$' AS year,

 (SELECT COUNT(*) FROM animal
 WHERE DateBroughtIn >= '$@year$-01-01' AND DateBroughtIn <= '$@year$-12-31'
 AND SpeciesID = 2 
 AND DateOfBirth > $SQL INTERVAL DateBroughtIn,-,6,months$
 AND NonShelterAnimal = 0) AS KittensIntake,
 
  (SELECT COUNT(*) FROM animal
 WHERE DateBroughtIn >= '$@year$-01-01' AND DateBroughtIn <= '$@year$-12-31'
 AND SpeciesID = 2 
 AND DateOfBirth < $SQL INTERVAL DateBroughtIn,-,6,months$
 AND NonShelterAnimal = 0) AS CatsIntake,
 
  (SELECT COUNT(*) FROM animal
 WHERE DateBroughtIn >= '$@year$-01-01' AND DateBroughtIn <= '$@year$-12-31'
 AND SpeciesID = 2 
 AND DateOfBirth > $SQL INTERVAL DateBroughtIn,-,8,weeks$
 AND NonShelterAnimal = 0) AS Under8WeekIntake,
 
  (SELECT COUNT(*) FROM animal
 WHERE DateBroughtIn >= '$@year$-01-01' AND DateBroughtIn <= '$@year$-12-31'
 AND SpeciesID = 2 
 AND DateOfBirth > $SQL INTERVAL DateBroughtIn,-,8,weeks$
 AND EntryTypeID = 5  
 AND NonShelterAnimal = 0) AS BornInCare,
 
   (SELECT COUNT(*) FROM animal
 WHERE DateBroughtIn >= '$@year$-01-01' AND DateBroughtIn <= '$@year$-12-31'
 AND SpeciesID = 2 
 AND DateOfBirth > $SQL INTERVAL DateBroughtIn,-,4,weeks$
 AND NonShelterAnimal = 0) AS Under4WeekIntake,
 
    (SELECT COUNT(*) FROM animal
 WHERE DateBroughtIn >= '$@year$-01-01' AND DateBroughtIn <= '$@year$-12-31'
 AND SpeciesID = 2 
 AND DateOfBirth < $SQL INTERVAL DateBroughtIn,-,4,weeks$
 AND DateOfBirth > $SQL INTERVAL DateBroughtIn,-,8,weeks$    
 AND NonShelterAnimal = 0) AS Between4And8week,
 
   (SELECT COUNT(*) FROM animal
 WHERE DateBroughtIn >= '$@year$-01-01' AND DateBroughtIn <= '$@year$-12-31'
 AND SpeciesID = 2 
 AND DateOfBirth > $SQL INTERVAL DateBroughtIn,-,8,weeks$
 AND EntryTypeID = 5  
 AND NonShelterAnimal = 0) AS BornInCare,
 
 (SELECT COUNT(*) FROM animal
INNER JOIN deathreason ON deathreason.ID = animal.PTSReasonID
WHERE DateBroughtIn >= '$@year$-01-01' AND DateBroughtIn <= '$@year$-12-31' 
AND DateOfBirth > $SQL INTERVAL DeceasedDate,-,8,weeks$ 
AND DiedOffShelter = 0 AND IsDOA = 0 AND PutToSleep = 1 AND NonShelterAnimal = 0) AS Euthanised,

 (SELECT COUNT(*) FROM animal
INNER JOIN deathreason ON deathreason.ID = animal.PTSReasonID
WHERE DateBroughtIn >= '$@year$-01-01' AND DateBroughtIn <= '$@year$-12-31' 
AND DateOfBirth > $SQL INTERVAL DeceasedDate,-,8,weeks$ 
AND DiedOffShelter = 0 AND IsDOA = 0 AND PutToSleep = 0 AND NonShelterAnimal = 0) AS DiedInCare
###
